# Copy this file to .env.local and fill in values before running locally.
# Add environment variables to the Vercel project dashboard for production.

# Site identity
NEXT_PUBLIC_SITE_NAME="SITE_NAME"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Email (Resend) — uncomment when you need contact forms
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_EMAIL=hello@your-domain.com

# CMS (Sanity) — uncomment when you need a CMS
# NEXT_PUBLIC_SANITY_PROJECT_ID=xxxx
# NEXT_PUBLIC_SANITY_DATASET=production

# Database (Supabase) — uncomment when you need a database
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
