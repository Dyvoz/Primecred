# Copy this file to .env.local and fill in values before running locally.
# Add the same variables to your Vercel project dashboard for production.

# ── Resend (email — required for contact form) ─────────────────────────────────
# 1. Create a free account at https://resend.com
# 2. Get your API key at https://resend.com/api-keys
# 3. For production: verify your domain at https://resend.com/domains
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address that RECEIVES form submissions (your inbox)
CONTACT_EMAIL=seuemail@seudominio.com

# The sender name/address (must be from a Resend-verified domain in production)
# For testing without a verified domain, leave as the default below:
FROM_EMAIL=PrimeCred <onboarding@resend.dev>

# ── Site ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://primecred.com.br
